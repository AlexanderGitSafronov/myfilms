generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  lists    MovieList[]
  likes    MovieLike[]
  comments Comment[]

  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MovieList {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  isPublic    Boolean  @default(true)
  coverImage  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  movies ListMovie[]

  @@unique([userId, slug])
  @@index([userId])
}

model Movie {
  id            String   @id @default(cuid())
  tmdbId        Int?     @unique
  title         String
  originalTitle String?
  overview      String?  @db.Text
  posterPath    String?
  posterUrl     String?
  backdropUrl   String?
  releaseDate   String?
  rating        Float?
  voteCount     Int?
  genres        String[]
  runtime       Int?
  language      String?
  sourceUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  listMovies ListMovie[]
  likes      MovieLike[]
  comments   Comment[]

  @@index([tmdbId])
}

model ListMovie {
  id      String   @id @default(cuid())
  listId  String
  movieId String
  order   Int      @default(0)
  note    String?
  addedAt DateTime @default(now())

  list  MovieList @relation(fields: [listId], references: [id], onDelete: Cascade)
  movie Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([listId, movieId])
  @@index([listId])
}

model MovieLike {
  id        String   @id @default(cuid())
  userId    String
  movieId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  movieId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId])
}
